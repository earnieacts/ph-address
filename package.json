{
  "name": "@aivangogh/ph-address",
  "version": "2025.4.4",
  "description": "A collection of philippine geographic data based on PSGC",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "LICENCE", "README.md"],
  "author": {
    "name": "Ivan Gemota",
    "email": "aivangogh.dev@gmail.com",
    "url": "https://github.com/aivangogh"
  },
  "repository": {
    "url": "git+ssh://git@github.com/aivangogh/ph-address.git"
  },
  "homepage": "https://aivangogh.github.io/tools/ph-address",
  "license": "MIT",
  "keywords": ["philippines", "address", "ph-address", "psgc"],
  "scripts": {
    "build:tsup": "tsup",
    "release": "npm run build && changeset publish",
    "test": "vitest",
    "test:prepare": "bun run build:csv-ts",
    "migrate:psgc": "bun scripts/migrate-psgc.ts",
    "build:csv-ts": "bun scripts/convert-to-csv.ts src/data-csv-ts/index.ts",
    "build": "bun run build:csv-ts && bun run build:tsup",
    "format": "prettier --write .",
    "benchmark": "bun run scripts/benchmark.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@toon-format/toon": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pako": "^2.0.4",
    "@vitest/coverage-v8": "^2.0.4",
    "prettier": "^3.3.2",
    "tsup": "^8.1.2",
    "typescript": "^5.2.2",
    "vitest": "^2.0.4",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "pako": "^2.1.0"
  }
}
